# --- Python ------------------------------------------------------------------
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# --- Secrets / config locale -------------------------------------------------
.env
config/mode.yaml                # copié depuis mode.example.yaml, non versionné

# --- Données runtime (persistées sous data/, jamais commit) ------------------
/data/
!/data/.gitkeep                 # garde le dossier dans git sans son contenu

# --- Déploiement -------------------------------------------------------------
.deployment.lock                # flock partagé deploy.sh ↔ auto-update.sh
.deploy.lock                    # legacy, au cas où un vieux clone traîne
.auto-update.lock               # legacy idem

# --- Self-improve (généré à chaque run hebdo) --------------------------------
IMPROVEMENTS_PENDING.md

# --- Historique MEMORY.md ----------------------------------------------------
MEMORY.history/

# --- Divers ------------------------------------------------------------------
*.log
.DS_Store
.idea/
.vscode/
