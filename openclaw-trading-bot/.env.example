# =============================================================================
# .env.example — copier vers .env et renseigner. Ne JAMAIS commit .env.
# Le fichier réel doit être chmod 600 et appartenir à l'utilisateur du VPS.
# =============================================================================

# --- Anthropic (obligatoire) -------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENCLAW_MODEL=claude-sonnet-4-6         # cycles : sonnet (§2.3)
OPENCLAW_MODEL_IMPROVE=claude-opus-4-7   # self-improve + archi-review (§2.3)

# --- Telegram (obligatoire pour validation humaine) --------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=                 # obligatoire — générer avec `openssl rand -hex 32`

# --- Dashboard — basic auth derrière Caddy -----------------------------------
DASHBOARD_BASIC_AUTH_USER=operator
DASHBOARD_BASIC_AUTH_PASS=                # obligatoire — générer avec `openssl rand -hex 24`

# --- Brokers & prix (paper/demo par défaut en V1) ----------------------------
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice                       # practice | live

ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# --- Crypto providers (ajoutés V1.1) -----------------------------------------
COINGECKO_DEMO_KEY=                      # optionnel — 10k req/mois avec clé
COINMARKETCAP_KEY=                       # requis pour global_metrics / fear_greed
# Kraken REST — pas de clé pour endpoints publics

# --- News & sentiment --------------------------------------------------------
NEWSAPI_KEY=                             # 100 req/j — fallback enrichissement
FINNHUB_KEY=                             # 60 req/min — news par ticker

# --- Macro -------------------------------------------------------------------
FRED_API_KEY=
TRADINGECONOMICS_KEY=                    # 500 req/j
# World Bank / OECD / Eurostat — pas de clé (APIs publiques)

# --- Simulation --------------------------------------------------------------
SIMULATION_INITIAL_EQUITY=10000
SIMULATION_BASE_CURRENCY=USD

# --- Mode & logs -------------------------------------------------------------
BOT_MODE=simulation                      # "simulation" en V1, jamais "live"
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR

# --- Version OpenClaw --------------------------------------------------------
# Tag logique embarqué dans l'image Docker (LABEL + ENV). Peut aussi être
# surchargé au runtime via : ./deploy.sh --openclaw-version=1.2.0
OPENCLAW_VERSION=latest

# --- Chemins (override possible, valeurs par défaut suffisent) ---------------
DATA_DIR=/app/data
MEMORY_DB_PATH=/app/data/memory.db
JOURNAL_XLSX_PATH=/app/data/simulation/journal.xlsx
